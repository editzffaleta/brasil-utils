{
  "name": "brasil-utils",
  "version": "0.0.0",
  "description": "Validação e formatação de dados brasileiros (CPF, CNPJ, CEP, telefone, Pix, placa) — zero dependências.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check:exports": "publint",
    "check:types": "attw --pack .",
    "size": "size-limit",
    "release": "changeset publish"
  },
  "keywords": [
    "cpf",
    "cnpj",
    "cep",
    "telefone",
    "pix",
    "placa",
    "brasil",
    "brazil",
    "validação",
    "validation",
    "zero-dependencies"
  ],
  "license": "MIT",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Bruno Faleta (https://github.com/editzffaleta)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/editzffaleta/brasil-utils.git"
  },
  "homepage": "https://github.com/editzffaleta/brasil-utils#readme",
  "bugs": {
    "url": "https://github.com/editzffaleta/brasil-utils/issues"
  }
}
